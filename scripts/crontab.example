# ============================================================
# 智能制造数据中台 - MySQL / InfluxDB 双向同步
# crontab 配置示例 (Linux)
# ============================================================
# 安装方式:
#   crontab -e
#   将以下行粘贴并保存
#   查看状态: crontab -l
# ============================================================

# ----------------------------- 全局环境变量 -----------------------------
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
HOME=/opt/smart-factory-sync
PYTHON_BIN=/usr/bin/python3

# ----------------------------- 日志与告警 -----------------------------
# 将错误发送到邮箱 (需系统配置好 mailx)
MAILTO=""

# ----------------------------- 同步任务定义 -----------------------------

# 1. 每5分钟 - 预览模式（安全，仅生成脚本不执行），便于人工审核
# 建议先运行至少一周预览模式，确认脚本无问题后再切换到执行模式
*/5 * * * *  cd $HOME && ./scripts/crontab_sync.sh preview >> logs/crontab_wrapper.log 2>&1

# 2. 每5分钟 - 执行模式（实际执行变更，失败自动回滚）
# 确认预览脚本无误后，取消下一行注释，并注释掉上面的预览任务
# */5 * * * *  cd $HOME && ./scripts/crontab_sync.sh execute >> logs/crontab_wrapper.log 2>&1

# 3. 每日凌晨3点 - 全量审计同步（即使没有变化也强制跑一次）
0 3 * * *   cd $HOME && ./scripts/crontab_sync.sh preview >> logs/daily_audit.log 2>&1

# 4. 每周日凌晨2点 - 清理30天前的日志
0 2 * * 0   find $HOME/logs -name "*.log*" -mtime +30 -delete 2>/dev/null; find $HOME/logs/sessions -name "*.json" -mtime +30 -delete 2>/dev/null

# ----------------------------- 心跳检测 -----------------------------
# 每分钟检查同步任务是否正常运行（可选）
# * * * * *   if [ ! -f $HOME/logs/cron_$(date +\%Y\%m\%d).log ]; then echo "SYNC CRON NOT RUNNING" | mail -s "告警: 同步任务未运行" admin@example.com; fi
